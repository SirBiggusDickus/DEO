# 4. Core algorithm loop

```python
for gen in range(max_generations):

    for i in range(pop_size):

        target = population[i]

        # 1. Mutation (Best1)
        best = get_best(population)
        r1, r2 = select_random_indices(exclude=i)

        mutant = best + F * (population[r1] - population[r2])

        # 2. Crossover (binomial)
        trial = crossover_binomial(target, mutant, CR)

        # 3. Bound handling
        trial = clip_to_bounds(trial)

        # 4. Selection
        if f(trial) < f(target):
            population[i] = trial

    update_best()
    log_history()
    update_plot()
```

